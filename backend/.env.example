# Digital Seva Platform - Environment Variables

# MongoDB Connection String
# For local development: mongodb://127.0.0.1:27017/digital_platform
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/digital_platform
MONGODB_URI=mongodb://127.0.0.1:27017/digital_platform

# JWT Secret Key (change this to a strong random string in production)
JWT_SECRET=mysecretkey123

# Server Port (Render will override this automatically)
PORT=5000

# CORS Allowed Origins (comma-separated)
# For production, add your deployed frontend URL
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
