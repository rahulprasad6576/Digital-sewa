# ============================================
# Digital Seva Platform - Environment Variables
# ============================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/digital_platform

# JWT Secret (generate a strong random string)
JWT_SECRET=your_super_secret_jwt_key_here

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:5500,http://127.0.0.1:5500

# ============================================
# RAZORPAY PAYMENT GATEWAY (Required for real payments)
# Get keys from: https://dashboard.razorpay.com/app/keys
# ============================================
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ============================================
# RECHARGE API PROVIDER (Required for real recharges)
# Supported providers: fast2sms, rechargekit, custom
# Get API keys from your chosen provider
# ============================================
RECHARGE_PROVIDER=custom
RECHARGE_API_URL=https://api.yourrechargeprovider.com
RECHARGE_API_KEY=your_recharge_api_key_here
RECHARGE_API_SECRET=your_recharge_api_secret_here

# Demo mode for recharges (set to false for real transactions)
RECHARGE_DEMO_MODE=true

# ============================================
# BILL PAYMENT API PROVIDER (Required for real bill payments)
# BBPS-compatible provider recommended
# ============================================
BILL_PROVIDER=custom
BILL_API_URL=https://api.yourbillprovider.com
BILL_API_KEY=your_bill_api_key_here
BILL_API_SECRET=your_bill_api_secret_here

# Demo mode for bill payments (set to false for real transactions)
BILL_DEMO_MODE=true

# ============================================
# EMAIL / SMS NOTIFICATIONS (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMS_API_KEY=your_sms_api_key

